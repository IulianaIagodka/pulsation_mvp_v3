{
  "expo": {
    "name": "Pulsation",
    "slug": "pulsation",
    "scheme": "pulsation",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D121E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maksym.pulsation",
      "buildNumber": "33",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "Pulsation sends a gentle reminder after you have been away for a while."
      }
    },
    "android": {
      "package": "com.maksym.pulsation",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D121E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#0D121E"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "54e2f20f-026c-4eae-8a39-b7e09729be1d"
      }
    },
    "owner": "iuliana.iagodka"
  }
}
